{
  "Name": "Govee Light Management",
  "Version": "2.0.0.0",
  "Author": "Felix Geelhaar",
  "URL": "https://github.com/felixgeelhaar/govee-light-management",
  "Actions": [
    {
      "Name": "On / Off",
      "UUID": "com.felixgeelhaar.govee-light-management.lights",
      "Icon": "imgs/actions/light/icon",
      "Tooltip": "Turn a light or group on/off",
      "PropertyInspectorPath": "ui/on-off.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/light/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "Name": "Brightness",
      "UUID": "com.felixgeelhaar.govee-light-management.brightness",
      "Icon": "imgs/actions/brightness-dial/icon",
      "Tooltip": "Set the brightness of a light or group",
      "PropertyInspectorPath": "ui/brightness.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/brightness-dial/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "Name": "Color",
      "UUID": "com.felixgeelhaar.govee-light-management.color",
      "Icon": "imgs/actions/colorhue-dial/icon",
      "Tooltip": "Set the color of a light or group",
      "PropertyInspectorPath": "ui/color.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/colorhue-dial/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "Name": "Color Temperature",
      "UUID": "com.felixgeelhaar.govee-light-management.colortemp",
      "Icon": "imgs/actions/colortemp-dial/icon",
      "Tooltip": "Set the color temperature of a light or group",
      "PropertyInspectorPath": "ui/color-temperature.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/colortemp-dial/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "Name": "Brightness Dial",
      "UUID": "com.felixgeelhaar.govee-light-management.brightness-dial",
      "Icon": "imgs/actions/brightness-dial/icon",
      "Tooltip": "Control brightness with Stream Deck+ dial",
      "PropertyInspectorPath": "ui/brightness-dial.html",
      "Controllers": ["Encoder"],
      "Encoder": {
        "Icon": "imgs/actions/brightness-dial/icon",
        "background": "imgs/actions/brightness-dial/background",
        "TriggerDescription": {
          "Rotate": "Adjust brightness",
          "Push": "Toggle power",
          "Touch": "N/A"
        },
        "layout": "$B1"
      },
      "States": [
        {
          "Image": "imgs/actions/brightness-dial/icon"
        }
      ]
    },
    {
      "Name": "Color Hue Dial",
      "UUID": "com.felixgeelhaar.govee-light-management.colorhue-dial",
      "Icon": "imgs/actions/colorhue-dial/icon",
      "Tooltip": "Control color with Stream Deck+ dial",
      "PropertyInspectorPath": "ui/colorhue-dial.html",
      "Controllers": ["Encoder"],
      "Encoder": {
        "Icon": "imgs/actions/colorhue-dial/icon",
        "background": "imgs/actions/colorhue-dial/background",
        "TriggerDescription": {
          "Rotate": "Change color",
          "Push": "Toggle power",
          "Touch": "N/A"
        },
        "layout": "$B1"
      },
      "States": [
        {
          "Image": "imgs/actions/colorhue-dial/icon"
        }
      ]
    },
    {
      "Name": "Color Temperature Dial",
      "UUID": "com.felixgeelhaar.govee-light-management.colortemp-dial",
      "Icon": "imgs/actions/colortemp-dial/icon",
      "Tooltip": "Control color temperature with Stream Deck+ dial",
      "PropertyInspectorPath": "ui/colortemp-dial.html",
      "Controllers": ["Encoder"],
      "Encoder": {
        "Icon": "imgs/actions/colortemp-dial/icon",
        "background": "imgs/actions/colortemp-dial/background",
        "TriggerDescription": {
          "Rotate": "Adjust warm/cool",
          "Push": "Toggle power",
          "Touch": "N/A"
        },
        "layout": "$B1"
      },
      "States": [
        {
          "Image": "imgs/actions/colortemp-dial/icon"
        }
      ]
    }
  ],
  "Category": "Govee Light Management",
  "CategoryIcon": "imgs/plugin/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "Control your Govee smart lights from Stream Deck",
  "Icon": "imgs/plugin/marketplace",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "UUID": "com.felixgeelhaar.govee-light-management"
}
